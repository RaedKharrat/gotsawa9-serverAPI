# Docker Postgres (docker-compose.yml maps host port 5435)
DATABASE_URL="postgresql://admin:adminpassword@localhost:5435/ecommerce?schema=public"
JWT_SECRET="change-me-in-production"
# Comma-separated storefront URLs (dev: any localhost port is also allowed automatically)
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"

# Cloudinary — from dashboard: Settings → API Keys
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Or separate variables:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
